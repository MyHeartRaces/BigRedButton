# Maintainer: Big Red Button contributors
pkgname=big-red-button
pkgver=0.2.1
pkgrel=1
pkgdesc='Desktop VPN launcher'
arch=('x86_64' 'aarch64')
url='https://github.com/MyHeartRaces/BigRedButton'
license=('MIT')
options=('!debug')
depends=('iproute2' 'nftables' 'polkit' 'systemd' 'util-linux' 'wireguard-tools' 'xdg-utils')
makedepends=('go')
optdepends=('wstunnel: WSTunnel client binary required for real connections')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  export CGO_ENABLED=0
  export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw -buildvcs=false"
  local ldflags="-s -w -X github.com/MyHeartRaces/BigRedButton/internal/buildinfo.Version=${pkgver}"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}" \
    "./cmd/${pkgname}"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}-gui" \
    "./cmd/${pkgname}-gui"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}d" \
    "./cmd/${pkgname}d"
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  export GOFLAGS="-mod=readonly -modcacherw -buildvcs=false"
  go test ./...
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "build/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm755 "build/${pkgname}-gui" "${pkgdir}/usr/bin/${pkgname}-gui"
  install -Dm755 "build/${pkgname}d" "${pkgdir}/usr/bin/${pkgname}d"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm755 "scripts/linux-smoke.sh" "${pkgdir}/usr/share/doc/${pkgname}/linux-smoke.sh"
  install -Dm644 "packaging/linux/${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
  install -Dm644 "packaging/assets/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
  install -Dm644 "packaging/linux/com.myheartraces.bigredbutton.policy" "${pkgdir}/usr/share/polkit-1/actions/com.myheartraces.bigredbutton.policy"
}
