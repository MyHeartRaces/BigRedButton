# Maintainer: Big Red Button contributors
pkgname=big-red-button
pkgver=0.1.0
pkgrel=1
pkgdesc='Headless Linux client for WireGuard over WSTunnel'
arch=('x86_64' 'aarch64')
url='https://github.com/MyHeartRaces/BigRedButton'
license=('MIT')
depends=('iproute2' 'wireguard-tools')
makedepends=('go')
optdepends=('wstunnel: WSTunnel client binary required for real connections')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  export CGO_ENABLED=0
  export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
  go build \
    -ldflags "-s -w" \
    -o "build/${pkgname}" \
    "./cmd/${pkgname}"
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  go test ./...
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "build/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
