# Maintainer: Big Red Button contributors
pkgname=big-red-button
pkgver=0.2.1
pkgrel=3
pkgdesc='Desktop VPN launcher'
arch=('x86_64' 'aarch64')
url='https://github.com/MyHeartRaces/BigRedButton'
license=('MIT')
options=('!debug')
depends=('desktop-file-utils' 'hicolor-icon-theme' 'iproute2' 'nftables' 'polkit' 'sudo' 'systemd' 'util-linux' 'wireguard-tools' 'xdg-utils')
makedepends=('go')
install="${pkgname}.install"
_wstunnel_ver=10.5.2
source=("${pkgname}-${pkgver}.tar.gz")
source_x86_64=("wstunnel-${_wstunnel_ver}-linux-amd64.tar.gz::https://github.com/erebe/wstunnel/releases/download/v${_wstunnel_ver}/wstunnel_${_wstunnel_ver}_linux_amd64.tar.gz")
source_aarch64=("wstunnel-${_wstunnel_ver}-linux-arm64.tar.gz::https://github.com/erebe/wstunnel/releases/download/v${_wstunnel_ver}/wstunnel_${_wstunnel_ver}_linux_arm64.tar.gz")
sha256sums=('SKIP')
sha256sums_x86_64=('7687e4354e91e856beb8d1d3bbf86f990f4cf752be639ad6d1f21b57c8191cf8')
sha256sums_aarch64=('ce6438391db8a83e22f204ae6cdcc87f96451409b90e76858997bb1a9cd85088')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  export CGO_ENABLED=0
  export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw -buildvcs=false"
  local ldflags="-s -w -X github.com/MyHeartRaces/BigRedButton/internal/buildinfo.Version=${pkgver}"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}" \
    "./cmd/${pkgname}"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}-gui" \
    "./cmd/${pkgname}-gui"
  go build \
    -ldflags "${ldflags}" \
    -o "build/${pkgname}d" \
    "./cmd/${pkgname}d"
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  export GOFLAGS="-mod=readonly -modcacherw -buildvcs=false"
  go test ./...
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "build/${pkgname}" "${pkgdir}/usr/bin/${pkgname}"
  install -Dm755 "build/${pkgname}-gui" "${pkgdir}/usr/bin/${pkgname}-gui"
  install -Dm755 "build/${pkgname}d" "${pkgdir}/usr/bin/${pkgname}d"
  install -Dm755 "${srcdir}/wstunnel" "${pkgdir}/usr/lib/${pkgname}/wstunnel"
  install -Dm755 "packaging/linux/${pkgname}-check.sh" "${pkgdir}/usr/bin/${pkgname}-check"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.wstunnel"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "${srcdir}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.wstunnel.md"
  install -Dm755 "scripts/linux-smoke.sh" "${pkgdir}/usr/share/doc/${pkgname}/linux-smoke.sh"
  install -Dm644 "packaging/linux/${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
  install -Dm644 "packaging/assets/${pkgname}.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/${pkgname}.svg"
  install -Dm644 "packaging/linux/com.myheartraces.bigredbutton.policy" "${pkgdir}/usr/share/polkit-1/actions/com.myheartraces.bigredbutton.policy"
  install -Dm644 "packaging/linux/${pkgname}d.service" "${pkgdir}/usr/lib/systemd/system/${pkgname}d.service"
}
