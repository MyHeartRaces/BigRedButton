{
  "protocol": "wireguard",
  "transport": "wstunnel",
  "server": "edge.example.com",
  "port": 443,
  "profile": "V7-WireGuard-WSTunnel-Direct",
  "sni": "edge.example.com",
  "wstunnel": {
    "mode": "wireguard-over-websocket",
    "url": "wss://edge.example.com:443/cdn/ws",
    "path": "/cdn/ws",
    "tls_server_name": "edge.example.com",
    "local_udp_listen": "127.0.0.1:51820"
  },
  "wireguard": {
    "private_key": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
    "public_key": "BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=",
    "server_public_key": "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC=",
    "preshared_key": "DDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDDD=",
    "address": "10.70.0.2/32",
    "allowed_ips": ["0.0.0.0/0", "::/0"],
    "dns": "1.1.1.1",
    "mtu": 1280,
    "persistent_keepalive": 25
  },
  "local_socks": {
    "listen": "127.0.0.1:18083",
    "auth": {
      "username": "local-user",
      "password": "local-pass"
    }
  }
}

